{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    },
    "mongodb": {
      "command": "npx",
      "args": [
        "-y",
        "mongo-mcp",
        "mongodb://localhost:27017/ttp_db"
      ]
    },
    "firebase": {
      "command": "npx",
      "args": [
        "-y",
        "@gannonh/firebase-mcp"
      ],
      "env": {
        "SERVICE_ACCOUNT_KEY_PATH": "/absolute/path/to/firebase-adminsdk.json",
        "MCP_HTTP_PORT": "3333"
      }
    },
    "stripe": {
      "command": "npx",
      "args": [
        "-y",
        "@stripe/mcp"
      ],
      "env": {
        "STRIPE_API_KEY": "sk_test_YOUR_STRIPE_SECRET_KEY_HERE"
      }
    }
  }
}
